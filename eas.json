{
  "build": {
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true,
        "distribution": "internal"
      }
    },
    "preview2": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true,
        "distribution": "internal"
      }
    },
    "tunnel-preview": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true,
        "distribution": "internal"
      },
      "env": {
        "EXPO_UPDATE_URL": "https://u.expo.dev/your-update-channel-id",
        "EXPO_RUNTIME_VERSION": "1.0.0"
      }
    },
    "development": {
      "android": {
        "buildType": "apk",
        "distribution": "internal"
      },
      "ios": {
        "simulator": true,
        "distribution": "internal"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "distribution": "store"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "your-apple-id@example.com",
        "ascAppId": "123456789",
        "appleTeamId": "ABC123DEF4"
      }
    }
  },
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  }
}
