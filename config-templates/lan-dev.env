# Local Area Network Development Environment
# Same network development (fastest local option)

# Connection Mode
TUNNEL_MODE=lan

# Development Server (auto-detected)
EXPO_DEV_SERVER_URL=

# Update Channel
EXPO_UPDATE_CHANNEL=development

# Logging
EXPO_VERBOSE=false

# Update Settings
UPDATE_FALLBACK_TIMEOUT=30000
UPDATE_CHECK_FREQUENCY=ON_APP_RESUME

# Performance
LAN_BROADCAST=true
LAN_MULTICAST=true

# Development
SKIP_INSTALL=false
