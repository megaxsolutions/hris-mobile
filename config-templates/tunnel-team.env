# Team Tunnel Development Environment
# Multiple developers collaborating with shared tunnel

# Connection Mode (tunnel required for team)
TUNNEL_MODE=tunnel

# Development Server
EXPO_DEV_SERVER_URL=

# Update Channel (shared across team)
EXPO_UPDATE_CHANNEL=team-development

# Logging (enabled for team coordination)
EXPO_VERBOSE=true

# Update Settings
UPDATE_FALLBACK_TIMEOUT=30000
UPDATE_CHECK_FREQUENCY=ON_APP_RESUME

# Tunnel Configuration
TUNNEL_SHARE_URL=true
TUNNEL_SHARE_METHOD=url

# Team Settings
TEAM_SLACK_WEBHOOK=
TEAM_NOTIFICATION_ENABLED=false

# Development
SKIP_INSTALL=false
