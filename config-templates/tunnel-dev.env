# Tunnel Development Environment
# Single developer using tunnel for remote testing

# Connection Mode
TUNNEL_MODE=tunnel

# Development Server
EXPO_DEV_SERVER_URL=

# Update Channel
EXPO_UPDATE_CHANNEL=development

# Logging
EXPO_VERBOSE=true

# Update Settings
UPDATE_FALLBACK_TIMEOUT=30000
UPDATE_CHECK_FREQUENCY=ON_APP_RESUME

# Cache Settings
EXPO_CACHE_DIR=.expo/cache

# Build Configuration
SKIP_INSTALL=false
