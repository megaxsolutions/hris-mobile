# Localhost Development Environment
# Single machine development (no network required)

# Connection Mode
TUNNEL_MODE=localhost

# Development Server
EXPO_DEV_SERVER_URL=http://localhost:8081

# Update Channel
EXPO_UPDATE_CHANNEL=dev-localhost

# Logging
EXPO_VERBOSE=false

# Update Settings
UPDATE_FALLBACK_TIMEOUT=30000
UPDATE_CHECK_FREQUENCY=ON_LOAD

# Server Port
EXPO_SERVER_PORT=8081

# Development
SKIP_INSTALL=false
