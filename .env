# Backend Environment Selection
# Options: local | staging | production
EXPO_PUBLIC_APP_ENV=local

# Backend API URLs per environment
EXPO_PUBLIC_API_URL_LOCAL=http://localhost:8000
EXPO_PUBLIC_API_URL_LOCAL_ANDROID=http://10.0.2.2:8000
EXPO_PUBLIC_API_URL_STAGING=https://staging-api.syncorpph.com/api
EXPO_PUBLIC_API_URL_PRODUCTION=https://api.syncorpph.com/api

EXPO_PUBLIC_API_URL=https://api.syncorpph.com/api
EXPO_PUBLIC_APP_NAME=NEO
EXPO_PUBLIC_VERSION=1.0.0
# Expo Tunnel Environment Configuration
# Copy this file to .env and update with your settings

# Tunnel Connection Mode
# Options: tunnel | lan | localhost
TUNNEL_MODE=tunnel

# Custom Development Server URL (optional)
# Leave empty to auto-generate tunnel URL
EXPO_DEV_SERVER_URL=

# EAS Update Channel
# Use 'production' for main builds, 'staging' for testing
EXPO_UPDATE_CHANNEL=default

# Verbose Logging
# Set to true for detailed tunnel connection logging
EXPO_VERBOSE=false

# Update Fallback Timeout (milliseconds)
# Time to wait for update before using cached version
UPDATE_FALLBACK_TIMEOUT=30000

# Update Check Frequency
# Options: ON_APP_RESUME | ON_LOAD | NEVER
UPDATE_CHECK_FREQUENCY=ON_APP_RESUME

# API Configuration (from src/utils/config.ts)
# These should match your backend configuration
REACT_NATIVE_API_URL=https://your-api-endpoint.com/api
REACT_NATIVE_WEBSOCKET_URL=wss://your-websocket-endpoint.com

# Feature Flags
ENABLE_FACE_LOGIN=true
ENABLE_LOCATION_TRACKING=true
ENABLE_OFFLINE_MODE=false

# Build Configuration
# Android
ANDROID_PACKAGE_NAME=com.megax.employeeapp

# iOS
IOS_BUNDLE_ID=com.megax.employeeapp
IOS_BUILD_NUMBER=1

# EAS Configuration
EAS_PROJECT_ID=
EAS_ANDROID_CHANNEL=production
EAS_IOS_CHANNEL=production

# google services
GOOGLE_SERVICES_JSON_PATH=./google-services.json
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyAYavyprK00u6C3Nz0UfrxiM3_ufTjob9o
